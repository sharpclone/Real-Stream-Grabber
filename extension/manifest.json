{
  "manifest_version": 2,
  "name": "Real Stream Grabber",
  "version": "2.0.26",
  "description": "Detects media streams, supports HLS variants, YouTube quick downloads (video/audio + playlists), cookie-based downloads, filename prompts, and native yt-dlp integration.",
  "author": "Sharpclone1",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "activeTab",
    "tabs",
    "storage",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Media Grabber",
    "default_icon": {
      "16": "icons/icon-16.webp",
      "32": "icons/icon-32.webp",
      "48": "icons/icon-48.webp",
      "128": "icons/icon-128.webp"
    }
  },
  "icons": {
    "16": "icons/icon-16.webp",
    "32": "icons/icon-32.webp",
    "48": "icons/icon-48.webp",
    "128": "icons/icon-128.webp"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "cazacmihaihack@gmail.com",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
